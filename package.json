{
  "name": "fluent-sorter",
  "version": "1.1.0",
  "description": "Lightweight fluent sorting helpers with ESM and CJS support.",
  "author": {
    "email": "admin@venipa.net",
    "name": "Venipa",
    "url": "https://venipa.net/projects/sortby"
  },
  "repository": "https://github.com/venipa/sortby.git",
  "bugs": {
    "url": "https://github.com/venipa/sortby/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "build": "bun run build:esm && bun run build:cjs && bun run build:types",
    "build:esm": "bun build ./index.ts --outfile ./dist/index.js --format esm --target node",
    "build:cjs": "bun build ./index.ts --outfile ./dist/index.cjs --format cjs --target node",
    "build:types": "bunx tsc ./index.ts --declaration --emitDeclarationOnly --outDir ./dist --module ESNext --target ESNext --skipLibCheck",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
