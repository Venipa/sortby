{
  "name": "fluent-sorter",
  "version": "1.1.6",
  "description": "Lightweight fluent sorting helpers with ESM and CJS support.",
  "author": {
    "email": "admin@venipa.net",
    "name": "Venipa",
    "url": "https://venipa.net/projects/sortby"
  },
  "repository": "https://github.com/venipa/sortby.git",
  "bugs": {
    "url": "https://github.com/venipa/sortby/issues"
  },
  "main": "./dist/index.cjs",
