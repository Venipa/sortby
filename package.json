    "build": "bun run build.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.21.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
